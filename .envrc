# shellcheck shell=bash
#
# Point the Dagger CLI/SDK at the shared engine running on this host as a systemd
# service (dagger-engine.service, unix socket), so `make test` / `dagger call`
# run against the same pinned engine CI uses (see otelhouse#33).
#
# This replaces the old global /etc/profile.d/dagger.sh, which exported the same
# variable for every login shell. That file was removed so the runner-host
# config travels per-project via direnv instead of polluting every shell.
export _EXPERIMENTAL_DAGGER_RUNNER_HOST="unix:///run/dagger/engine.sock"
